        <locationX>176</locationX>
        <locationY>252</locationY>
        <defaultConnector>
            <targetReference>Belgium_Users_On_Vacation</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Eligible</defaultConnectorLabel>
        <rules>
            <name>Not_Eligible</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ProfileID_Exclusion</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>UserProfileID</elementReference>
                </rightValue>
            </conditions>
            <label>Not Eligible</label>
        </rules>
    </decisions>
    <decisions>
        <name>Need_To_Roll_Back_Champion_Data</name>
        <label>Need To Roll Back Champion Data ?</label>
        <locationX>1727</locationX>
        <locationY>1092</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Revert</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>backupChampionData</leftValueReference>
