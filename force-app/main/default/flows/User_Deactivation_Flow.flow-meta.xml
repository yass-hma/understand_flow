                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Roll_Back_Champion_Data</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>Alias_VirtualUser</name>
        <dataType>String</dataType>
        <expression>&apos;VU&apos;+Right({!CreatedDateCleaned}, 5)</expression>
    </formulas>
    <formulas>
        <name>CreatedDateCleaned</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(SUBSTITUTE(TRIM(Text({!$Record.CreatedDate})), &apos;-&apos;, &apos;&apos;), &apos;:&apos;, &apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>NDays</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Label.UserDeactivationLimit})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>NumberOfDaysSinceCreation</name>
        <dataType>Number</dataType>
        <expression>TODAY() - {!CreatedDateVar}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>NumberOfDaysSinceLastLogin</name>
        <dataType>Number</dataType>
        <expression>TODAY() - {!LastLoginDateVAR}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>NumberOfDaysSinceModified</name>
        <dataType>Number</dataType>
        <expression>TODAY() - {!LastModifiedDateVAR}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Profiles to exclude</description>
        <name>ProfileID_Exclusion</name>
        <dataType>String</dataType>
        <expression>{!$label.UserDeactivationProfilesToBeExcluded}</expression>
    </formulas>
    <formulas>
        <description>to remove spaces in between record alias</description>
        <name>RecordAlias</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!$Record.Alias}, &apos; &apos;,&apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>timeStampCleaned</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(TRIM(Text({!$Flow.CurrentDateTime})), &apos;-&apos;, &apos;&apos;), &apos;:&apos;, &apos;&apos;), &apos; &apos;, &apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>virtualUserName</name>
        <dataType>String</dataType>
        <expression>&apos;VirtualUser_&apos;&amp;{!RecordAlias}&amp;&apos;_&apos;&amp;{!Alias_VirtualUser}&amp;&apos;_&apos;&amp;Left({!timeStampCleaned}, 8)&amp;&apos;@aldautomotive.com&apos;</expression>
    </formulas>
