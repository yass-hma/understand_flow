    <decisions>
        <name>Belgium_Users_On_Vacation</name>
        <label>Belgium Users On Vacation</label>
        <locationX>429</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Is_Created_Date_Less_Than_N_Days</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_BEL</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Subsidiary__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Belgium</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.On_Vacations__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Days_Since_Last_Login</name>
        <label>Days Since Last Login</label>
        <locationX>891</locationX>
        <locationY>576</locationY>
        <defaultConnectorLabel>Under N Days Since Logged In</defaultConnectorLabel>
        <rules>
            <name>Never_Logged_in</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NumberOfDaysSinceLastLogin</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Deactivate_User</targetReference>
            </connector>
            <label>Never Logged in</label>
        </rules>
        <rules>
            <name>Over_N_Days_Since_Logged_In</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NumberOfDaysSinceLastLogin</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>NDays</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Deactivate_User</targetReference>
            </connector>
            <label>Over N Days Since Logged In</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Champion_Field_need_to_be_cleaned</name>
        <label>Does Champion Field need to be cleaned ?</label>
        <locationX>1529</locationX>
        <locationY>984</locationY>
        <defaultConnector>
            <targetReference>Need_To_Roll_Back_Champion_Data</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Flow.FaultMessage</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Champion</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Take_Champion_field_Backup</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Created_Date_Less_Than_N_Days</name>
        <label>Is Modified Date Less Than N Days</label>
        <locationX>671</locationX>
        <locationY>468</locationY>
        <defaultConnector>
            <targetReference>Days_Since_Last_Login</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Over N Days</defaultConnectorLabel>
        <rules>
            <name>Under_N_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NumberOfDaysSinceModified</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>NDays</elementReference>
                </rightValue>
            </conditions>
            <label>Under N Days</label>
        </rules>
    </decisions>
    <decisions>
        <description>This stage excludes the tech profiles which should not be deactivated</description>
        <name>Is_Profile_Eligible_for_Deactivation</name>
