<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <interviewLabel>Populate ReadOnly Fields on Meeting Report {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Populate ReadOnly Fields on Meeting Report</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Meeting_Report</name>
        <label>Update Meeting Report</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <inputAssignments>
            <field>Account_Owner_at_meeting__c</field>
            <value>
                <elementReference>$Record.Account__r.Owner.Full_Name__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Account_Status_at_meeting__c</field>
            <value>
                <elementReference>$Record.Account__r.Status__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Fleet_Size_at_meeting__c</field>
            <value>
                <elementReference>$Record.Account__r.Total_Fleet_This_Account__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Total_Fleet_Potential_at_meeting__c</field>
            <value>
                <elementReference>$Record.Account__r.Total_Fleet_Potential__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Meeting_Report</targetReference>
        </connector>
        <filterFormula>AND(
NOT({!$User.Bypass_Workflow__c}),
NOT(ISNULL({!$Record.Account__c}))
)</filterFormula>
        <object>Meeting_Report__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
