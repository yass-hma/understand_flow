    <start>
        <locationX>439</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Get_Email_Template</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
NOT({!$User.Bypass_Workflow__c}),
{!$Record.RecordType.DeveloperName} = &apos;Case_External_Mexico&apos;,
NOT(ISBLANK({!$Record.ContactId})),
NOT(ISBLANK({!$Record.Contact.Email})),
NOT(ISBLANK({!$Record.Contract__c})),
NOT(ISBLANK({!$Record.Contract__r.CustomerSignedId})),
NOT(ISBLANK({!$Record.Contract__r.CustomerSigned.Email})),
NOT(ISBLANK({!$Record.AccountId})),
NOT(ISBLANK({!$Record.Appointment_date_time__c})),
NOT(ISBLANK(TEXT({!$Record.Synchronization_status__c}))),
ISPICKVAL({!$Record.Synchronization_status__c}, &quot;PROCESSED&quot;),
ISPICKVAL({!$Record.Maintenance_Status__c}, &quot;STATE_APPOINTMENT&quot;)
)</filterFormula>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
