    <description>Original version before the deployment of BR-7451</description>
    <environments>Default</environments>
    <formulas>
        <name>EndDate_Criteria</name>
        <dataType>Boolean</dataType>
        <expression>OR(
	AND(
	OR(
	IsNew(),
	ISCHANGED( {!$Record.Forecast_End_Date__c} )
	),
	If( IsNew() , NOT(ISBLANK({!$Record.Forecast_End_Date__c})), 
	NOT (YEAR( PRIORVALUE({!$Record.Forecast_End_Date__c} ) ) = YEAR({!$Record.Forecast_End_Date__c} ) )),
	NOT({!$Record.Forecast_End_Date__c} &lt; TODAY()),	
	If(YEAR({!$Record.Forecast_End_Date__c} ) &gt;= YEAR( TODAY() ) + 2, NOT(ISBLANK({!$Record.Opportunity__c})), true)
	),
	AND(
	OR(
	IsNew(),
	ISCHANGED( {!$Record.Real_lease_end_date__c} )
	),
	If( IsNew() , NOT(ISBLANK({!$Record.Real_lease_end_date__c})), 
	NOT (YEAR( PRIORVALUE({!$Record.Real_lease_end_date__c} ) ) = YEAR({!$Record.Real_lease_end_date__c} ) )),
	NOT({!$Record.Real_lease_end_date__c} &lt; TODAY()),	
	If(YEAR({!$Record.Real_lease_end_date__c} ) &gt;= YEAR( TODAY() ) + 2, NOT(ISBLANK({!$Record.Opportunity__c})), true)
	),
	AND(
	OR(
	IsNew(),
	ISCHANGED( {!$Record.EndDate} )
	),
	If( IsNew() , NOT(ISBLANK({!$Record.EndDate})), 
	NOT (YEAR( PRIORVALUE({!$Record.EndDate} ) ) = YEAR({!$Record.EndDate} ) )),
	NOT({!$Record.EndDate} &lt; TODAY()),	
	If(YEAR({!$Record.EndDate} ) &gt;= YEAR( TODAY() ) + 2, NOT(ISBLANK({!$Record.Opportunity__c})), true)
	)
)</expression>
    </formulas>
    <interviewLabel>Capture the End Date Change of a Contrat {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Capture the End Date Change of a Contract</label>
