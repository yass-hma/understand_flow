    <decisions>
        <name>Is_V3_Enabled</name>
        <label>Is V3 Enabled ?</label>
        <locationX>383</locationX>
        <locationY>301</locationY>
        <defaultConnector>
            <targetReference>If_Contract_is_in_scope</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_V3_Enabled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Related_Subsidiary_Setting.Opportunity_Renewal_V3_Enabled__c</leftValueReference>
