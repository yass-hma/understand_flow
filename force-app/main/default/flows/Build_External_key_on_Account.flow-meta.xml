AND(NOT(OR(ISNULL(TEXT({!$Record.Identification_Criteria__c})), ISBLANK(TEXT({!$Record.Identification_Criteria__c})))), NOT(OR(ISBLANK(TEXT({!$Record.Subsidiary_Indicator__c})), ISNULL(TEXT({!$Record.Subsidiary_Indicator__c})))))
