OR(ISCHANGED({!$Record.Local_CALDER_ID__c}), ISCHANGED({!$Record.Subsidiary_Indicator__c})),
NOT(ISCHANGED({!$Record.ExternalId__c})),
AND(NOT(OR(ISNULL({!$Record.Local_CALDER_ID__c}), ISBLANK({!$Record.Local_CALDER_ID__c}))), NOT(OR(ISBLANK(TEXT({!$Record.Subsidiary_Indicator__c})), ISNULL(TEXT({!$Record.Subsidiary_Indicator__c})))))
