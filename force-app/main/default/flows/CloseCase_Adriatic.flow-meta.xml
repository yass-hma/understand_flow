<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>TargetURL_OtherCategory</name>
        <label>TargetURL_OtherCategory</label>
        <locationX>379</locationX>
        <locationY>516</locationY>
        <assignmentItems>
            <assignToReference>vFinalLocation</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>/{!vCaseId}/s?cas7=Closed&amp;nooverride=1&amp;retURL=/{!vCaseId}</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>TargetURL_QualityManagement</name>
        <label>TargetURL_QualityManagement</label>
        <locationX>595</locationX>
        <locationY>516</locationY>
        <assignmentItems>
            <assignToReference>vFinalLocation</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>/apex/caseCloseCategory?ID={!vCaseId}</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>WhatIsTheCategory</name>
        <label>WhatIsTheCategory</label>
        <locationX>479</locationX>
        <locationY>359</locationY>
        <defaultConnectorLabel>[Default Outcome]</defaultConnectorLabel>
        <rules>
            <name>CategoryQualityManagement</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>vCategoryCase</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Quality management</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>TargetURL_QualityManagement</targetReference>
            </connector>
            <label>CategoryQualityManagement</label>
        </rules>
        <rules>
            <name>OtherCategory</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>vCategoryCase</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Quality management</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>TargetURL_OtherCategory</targetReference>
            </connector>
            <label>OtherCategory</label>
        </rules>
    </decisions>
    <description>2 cases : When Category is Quality management
When Category is not Quality Management</description>
    <interviewLabel>CloseCase_Adriatic {!$Flow.CurrentDateTime}</interviewLabel>
    <label>CloseCase_Adriatic</label>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>CaseLookup</name>
        <label>CaseLookup</label>
        <locationX>478</locationX>
        <locationY>243</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>WhatIsTheCategory</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>vCaseId</elementReference>
            </value>
        </filters>
        <object>Case</object>
        <outputAssignments>
            <assignToReference>vCategoryCase</assignToReference>
            <field>External_Case_Category__c</field>
        </outputAssignments>
    </recordLookups>
    <startElementReference>CaseLookup</startElementReference>
    <status>Active</status>
    <variables>
        <description>variable Id du Case</description>
        <name>vCaseId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>variable Category du Case</description>
        <name>vCategoryCase</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>vFinalLocation</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
