    <decisions>
        <description>Set Guarantee to true if type is filled
If Guarantee type is filled then set Guarantee to true
If Guarantee type is empty then set Guarantee to false</description>
        <name>FRA_Update_Guarantee</name>
        <label>FRA - Update Guarantee</label>
        <locationX>314</locationX>
        <locationY>311</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>FRA_GuaranteeCheck</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Guarantee_Type__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Guarantee__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>FRA_Guarantee_Check</targetReference>
            </connector>
            <label>FRA - GuaranteeCheck</label>
        </rules>
        <rules>
            <name>FRA_GuaranteeUnCheck</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Guarantee_Type__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Guarantee__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>FRA_Guarantee_Uncheck</targetReference>
            </connector>
            <label>FRA - GuaranteeUnCheck</label>
        </rules>
