    <recordUpdates>
        <description>Cancel related quotes to Lost Opps</description>
        <name>Cancel_Related_Quotes</name>
        <label>Cancel Related Quotes</label>
        <locationX>578</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Canceled</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Quotes</inputReference>
    </recordUpdates>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_New_Opportunity</targetReference>
        </connector>
        <filterFormula>AND(
    NOT({!$User.Bypass_Workflow__c}),    
    NOT(CONTAINS({!$Label.FrenchOppRecTypeDevName}, {!$Record.RecordType.DeveloperName})),
    OR(
        AND(
            ISPICKVAL({!$Record.StageName}, &quot;Closed Lost&quot;),
            NOT(ISBLANK(TEXT({!$Record.StageName})))
        ),
        AND(
			NOT(ISBLANK({!$Record.RecordType.DeveloperName})),
            OR(
                NOT(ISBLANK({!$Record.Vehicle_segment__c})),
                NOT(ISBLANK({!$Record.Fuel_type__c})),
                NOT(ISBLANK({!$Record.Engine_size__c})),
                NOT(ISBLANK(TEXT({!$Record.Make__c}))),
                NOT(ISBLANK({!$Record.Model__c})),
                NOT(ISBLANK({!$Record.Mileage_range__c})),
                NOT(ISBLANK({!$Record.Duration__c})),
                NOT(ISBLANK({!$Record.Downpayment__c})),
                NOT(ISBLANK({!$Record.Price_range__c})),
                NOT(ISBLANK({!$Record.Price_Including_VAT__c}))
            )
        )
    )
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
