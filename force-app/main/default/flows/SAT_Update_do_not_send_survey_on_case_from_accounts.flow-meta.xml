        <label>Update related cases</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>CasesToUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Account_Subsidiary</targetReference>
        </connector>
        <filterFormula>AND (
NOT({!$User.Bypass_Workflow__c}),
{!$Record.Do_not_send_survey__c} != {!$Record__Prior.Do_not_send_survey__c},
CONTAINS({!$Label.Satmetrix_Countries}, TEXT({!$Record.Subsidiary__c})))</filterFormula>
        <object>Account</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
