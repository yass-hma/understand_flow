    <decisions>
        <name>Check_if_the_queue_is_customer_care</name>
        <label>Check if the queue is customer care</label>
        <locationX>1568</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_the_queue_is_customer_care</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.OwnerId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_customer_care_queue_Id.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_the_contact_type</targetReference>
            </connector>
            <label>If the queue is customer care</label>
        </rules>
    </decisions>
