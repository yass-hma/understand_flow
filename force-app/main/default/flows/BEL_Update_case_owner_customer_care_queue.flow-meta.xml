    <decisions>
        <name>Check_the_customer_class_values</name>
        <label>Check the customer class values</label>
        <locationX>974</locationX>
        <locationY>755</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_the_customer_class_is_Corporate_benefit</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Corporate Benefit</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_BEL_C_D_Benefit_queue</targetReference>
            </connector>
            <label>If the customer class is &apos;Corporate benefit&apos;</label>
        </rules>
        <rules>
            <name>If_the_customer_class_is_corporate_value</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Corporate Value</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_BEL_C_D_Value_queue_Id</targetReference>
            </connector>
            <label>If the customer class is &apos;corporate value&apos;</label>
        </rules>
        <rules>
            <name>If_the_customer_class_are_direct_retail</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retail Direct B2B 10-24</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retail Direct B2B 1-9</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retail Indirect B2B</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retail Indirect B2C</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Customer_Class__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retail Direct B2C</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_BEL_C_D_SME_Private_queue_Id</targetReference>
            </connector>
            <label>If the customer class are direct retail</label>
        </rules>
    </decisions>
