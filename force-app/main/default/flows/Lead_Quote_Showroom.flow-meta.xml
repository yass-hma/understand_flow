    <recordUpdates>
        <description>cancel all quotes related to triggering lead</description>
        <name>cancel_linked_quotes</name>
        <label>cancel linked quotes</label>
        <locationX>462</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Canceled</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Quotes__r</inputReference>
