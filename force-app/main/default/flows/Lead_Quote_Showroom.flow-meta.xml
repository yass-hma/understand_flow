    <decisions>
        <name>Is_New_Lead</name>
        <label>Is New Lead ?</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Change_in_Quotation_Fields</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Italy_Eloqua_Created_lead</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsNewLead</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Subsidiary_ID__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>38001</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Label.SkipUserfromBypassLeadQuoteFlow</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>$User.Id</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.IsConverted</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>Italy Eloqua Created lead</label>
        </rules>
        <rules>
            <name>Yes_New_Lead</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsNewLead</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Quote</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>This is used for creation of quotes when lead is created or updated with a certain criteria. 
Whenever the lead status is sales disqualified, mark the quote status as canceled</description>
    <environments>Default</environments>
    <formulas>
        <description>Today&apos;s date  formatted to YYYYMMDD</description>
        <name>formattedDate</name>
        <dataType>String</dataType>
        <expression>TEXT(YEAR({!TodayDate})) &amp; IF(MONTH({!TodayDate}) &lt;10 , &quot;0&quot; &amp; TEXT(MONTH({!TodayDate})), TEXT(MONTH({!TodayDate}))) &amp; IF(DAY({!TodayDate}) &lt;10 , &quot;0&quot; &amp; TEXT(DAY({!TodayDate})), TEXT(DAY({!TodayDate})))</expression>
    </formulas>
    <formulas>
        <name>IsNewLead</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>QuoteNameFormula</name>
        <dataType>String</dataType>
        <expression>{!$Record.Company} &amp; &quot; &quot;&amp; {!$Record.Partner__r.Name} &amp; &quot; &quot; &amp; {!formattedDate}</expression>
    </formulas>
    <formulas>
        <name>TodayDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
