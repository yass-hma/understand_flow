    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_New_Lead</targetReference>
        </connector>
        <filterFormula>AND(
    OR(
    NOT({!$User.Bypass_Workflow__c}),
	CONTAINS({!$Label.SkipUserfromBypassLeadQuoteFlow},{!$User.Id})),
    NOT(CONTAINS({!$Label.FrenchLeadRecTypeDevName}, {!$Record.RecordType.DeveloperName})),
    OR(
        AND(
            ISPICKVAL({!$Record.Status}, &quot;Sales Disqualified&quot;),
            NOT(ISBLANK(TEXT({!$Record.Status})))
        ),
        AND(
			NOT(ISBLANK({!$Record.RecordType.DeveloperName})),
            OR(
                NOT(ISBLANK({!$Record.Vehicle_segment__c})),
                NOT(ISBLANK({!$Record.Fuel_type__c})),
                NOT(ISBLANK({!$Record.Engine_size__c})),
                NOT(ISBLANK({!$Record.Make__c})),
                NOT(ISBLANK({!$Record.Model__c})),
                NOT(ISBLANK({!$Record.Mileage_range__c})),
                NOT(ISBLANK({!$Record.Duration__c})),
                NOT(ISBLANK({!$Record.Downpayment__c})),
                NOT(ISBLANK({!$Record.Price_range__c})),
                NOT(ISBLANK({!$Record.Price_Including_VAT__c}))
            )
        )
    )
)</filterFormula>
        <object>Lead</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
