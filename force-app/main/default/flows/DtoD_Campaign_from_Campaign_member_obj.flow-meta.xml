        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <name>Day_to_Day_Campaign_lookup</name>
        <label>Day to Day Campaign lookup</label>
        <locationX>672</locationX>
        <locationY>30</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Campaign_members_assigned_to_lead</targetReference>
        </connector>
        <filterLogic>(1 AND 2 AND 3 AND 5) OR (1 AND 3 AND 4 AND 6)</filterLogic>
        <filters>
            <field>Day_to_Day_Campaign__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Partner_bu__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>vLeadPartner</elementReference>
            </value>
        </filters>
        <filters>
            <field>Subsidiary_all__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Vleadcampid</elementReference>
            </value>
        </filters>
        <filters>
            <field>Partner_Account__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>PartnerAccount</elementReference>
            </value>
        </filters>
        <filters>
            <field>Campaign_Partner_RecordType__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Partner_Account__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Campaign</object>
        <outputAssignments>
            <assignToReference>vD2DCampaignId</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <name>Lead_Lookup</name>
        <label>Lead Lookup</label>
        <locationX>527</locationX>
        <locationY>33</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Day_to_Day_Campaign_lookup</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>vCampaignmemberlk.LeadId</elementReference>
            </value>
        </filters>
        <object>Lead</object>
        <outputAssignments>
            <assignToReference>vLeadPartner</assignToReference>
            <field>Account_Environment__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>vLeadsubsidiary</assignToReference>
            <field>HQ_Country_Names_List__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>vLeadId</assignToReference>
            <field>Id</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>vLeadSource</assignToReference>
            <field>LeadSource</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>PartnerAccount</assignToReference>
            <field>Partner__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>Vleadcampid</assignToReference>
            <field>Subsidiary_ID__c</field>
        </outputAssignments>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
