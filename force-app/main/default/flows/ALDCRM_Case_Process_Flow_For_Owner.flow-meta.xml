    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>ISNEW() &amp;&amp; NOT($User.Bypass_Workflow__c) &amp;&amp; 
[Case].RecordType.DeveloperName == &apos;CaseExternalFrance&apos;  &amp;&amp; 
ISPICKVAL([Case].External_Case_Category__c, &apos;Insurance&apos;) &amp;&amp; 
NOT(ISBLANK([Case].AccountId)) &amp;&amp; 
CONTAINS($Label.ALD_Automotive, LEFT($User.Id,15)) &amp;&amp;
NOT(ISBLANK([Case].Account.Secondary_Account_Manager__c )) &amp;&amp; 
CONTAINS($Label.FRA_Case_GestionnaireSinsitres_Emails,[Case].Emailtocasereceiver__c) &amp;&amp; 
CONTAINS($Label.FRA_Case_GestionnaireSinsitres_Queues, LEFT([Case].OwnerId,15))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW() &amp;&amp; NOT({!$User.Bypass_Workflow__c}) &amp;&amp; 
{!myVariable_current.RecordType.DeveloperName} == &apos;CaseExternalFrance&apos;  &amp;&amp; 
ISPICKVAL({!myVariable_current.External_Case_Category__c}, &apos;Insurance&apos;) &amp;&amp; 
NOT(ISBLANK({!myVariable_current.AccountId})) &amp;&amp; 
CONTAINS({!$Label.ALD_Automotive}, LEFT({!$User.Id},15)) &amp;&amp;
NOT(ISBLANK({!myVariable_current.Account.Secondary_Account_Manager__c} )) &amp;&amp; 
CONTAINS({!$Label.FRA_Case_GestionnaireSinsitres_Emails},{!myVariable_current.Emailtocasereceiver__c}) &amp;&amp; 
CONTAINS({!$Label.FRA_Case_GestionnaireSinsitres_Queues}, LEFT({!myVariable_current.OwnerId},15))</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
