<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ALDSAT_Synchronization_Status</fullName>
    <active>false</active>
    <errorConditionFormula>AND(NOT( $User.Bypass_Validation_Rules__c ),CONTAINS($Label.ALDSATRecordTypeIds,RecordType.DeveloperName),
NOT(ISBLANK(TEXT(Synchronization_status__c))),
OR(ISCHANGED(External_Case_Category__c),ISCHANGED(External_Case_Detail__c ),ISCHANGED(Contract__c)))</errorConditionFormula>
    <errorMessage>As this case is synched with ALD Sat, Case Category ,Case Detail or Contract cannot be changed.</errorMessage>
</ValidationRule>
