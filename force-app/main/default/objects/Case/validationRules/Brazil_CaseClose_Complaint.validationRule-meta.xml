    <errorConditionFormula>AND(NOT($User.Bypass_Validation_Rules__c),RecordType.Name = &quot;Case External Brazil&quot;,ISPICKVAL(Status, &apos;Closed&apos;),NOT(ISPICKVAL(Complaint_justified__c,&apos;&apos;)),
