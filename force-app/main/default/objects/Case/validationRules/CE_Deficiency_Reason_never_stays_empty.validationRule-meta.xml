<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CE_Deficiency_Reason_never_stays_empty</fullName>
    <active>true</active>
    <description>If the picklist &quot;Deficiency Reason&quot; has no value then popup a message to the user. it always should be filled.</description>
    <errorConditionFormula>AND 
( 
NOT($User.Bypass_Validation_Rules__c ), 


ISPICKVAL(External_Case_Category__c,&quot;Quality management&quot;), 
ISBLANK(TEXT(Deficiency_reason__c)), 
OR(
$RecordType.Id =&apos;01220000000MEGh&apos; ,
$RecordType.Id =&apos;01220000000MGh8&apos; ,
$RecordType.Id =&apos;01220000000MDhj&apos; ,
$RecordType.Id =&apos;01220000000MFwy&apos; ,
$RecordType.Id =&apos;01220000000MG1A&apos; 
)
)</errorConditionFormula>
    <errorDisplayField>Deficiency_reason__c</errorDisplayField>
    <errorMessage>Please select a value within the &quot;Deficiency Reason&quot; picklist . It should never be left blank.</errorMessage>
</ValidationRule>
