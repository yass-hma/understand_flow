    <rules>
        <fullName>Peer Pricing Rating Status</fullName>
        <actions>
            <name>Rating_Status</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>set to active when a sales change a value</description>
        <formula>AND(ISPICKVAL(Status__c,&quot;Default&quot;), OR(ISCHANGED(Car_Policy__c), ISCHANGED(Car_Policy_Number_of_Reference__c), ISCHANGED(Nb_of_partners_for_contract_mngt__c), ISCHANGED(Negotiations_central_decentral_score__c), ISCHANGED(Presence_of_an_intermediary__c), ISCHANGED(Request_price_guarantee__c), ISCHANGED(Specific_treatments__c)))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Set Customer Rating updated by user</fullName>
        <actions>
            <name>Set_Last_Rate_Modified_Date</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Set_Last_update_By_user</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>if (OR(ISCHANGED(Specific_treatments__c), ISCHANGED(Request_price_guarantee__c), ISCHANGED(Presence_of_an_intermediary__c), ISCHANGED(Negotiations_centralized_decentralize__c), ISCHANGED(Nb_of_partners_for_contract_mngt__c), ISCHANGED(Car_Policy_Number_of_Reference__c), ISCHANGED(Car_Policy__c)),TRUE,FALSE)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
