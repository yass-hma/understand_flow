<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Alert_on_Expired_Event1</fullName>
        <description>Alert on Expired Event</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Tasksemailtemplates/Reminder_for_updating_the_meeting_minutes_and_the_status_of_the_event</template>
    </alerts>
    <rules>
        <fullName>CORE - Expired Event</fullName>
        <active>true</active>
        <description>This rule is an alert on meetings still in a planned status with start/end date in the past
Evaluation Criteria: Evaluate the rule when a record is created, and any time it&apos;s edited to subsequently meet criteria</description>
        <formula>NOT($User.Bypass_Workflow__c) &amp;&amp; 
CONTAINS($Label.Event_Meeting_Minute_Mandatory_Reminder, TEXT(Owner:User.Subsidiary_Indicator__c))&amp;&amp; 
Not(ISPICKVAL( Event_Status__c, &apos;Completed&apos;))</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Alert_on_Expired_Event1</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Event.EndDateTime</offsetFromField>
            <timeLength>2</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
