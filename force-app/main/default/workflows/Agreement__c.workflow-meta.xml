<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Agreement_Post_on_group</fullName>
        <description>Agreement Post on group</description>
        <protected>false</protected>
        <recipients>
            <recipient>INT_ALDi_Legal</recipient>
            <type>group</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>ALL/Agreement_details</template>
    </alerts>
    <alerts>
        <fullName>Agreement_Will_Expiry_in_9_months</fullName>
        <description>Agreement Will Expiry in 9 months</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Interalnational_Email_Tempalte/Automatic_reminder_for_international_agreement_to_expire</template>
    </alerts>
    <rules>
        <fullName>Send Notice Before 9 months of Agreement end date</fullName>
        <active>true</active>
        <description>PM-000423 - Active agreement, send Email notification 9 months before agreement end date</description>
        <formula>AND( Agreement_end_date__c &gt; TODAY()+ 270,
Active_Agreement__c = True)</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Agreement_Will_Expiry_in_9_months</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Agreement__c.Agreement_end_date__c</offsetFromField>
            <timeLength>-270</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
</Workflow>
