    <rules>
        <fullName>Alert Opportunity Owner 1 day before CloseDate</fullName>
        <active>true</active>
        <description>Create a tast, send an email 1 day before CloseDate for Opportunity International Owner</description>
        <formula>AND( NOT($User.Bypass_Workflow__c),RecordType.DeveloperName = &apos;OpportunityInternational&apos;, NOT(IsClosed), CloseDate &gt;  TODAY())</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Email_Alert_for_Internation_Opp_Owner_when_the_closed_is_past</name>
                <type>Alert</type>
            </actions>
            <actions>
                <name>Opportunity_is_not_yet_closed</name>
                <type>Task</type>
            </actions>
            <offsetFromField>Opportunity.CloseDate</offsetFromField>
            <timeLength>-1</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
    <rules>
        <fullName>Calculate Nb Vehicles Based On Contracts</fullName>
        <actions>
            <name>Update_Nb_Vehicles_Only_for_Renewal_Opty</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Only occurs for Renewal Opportunities Record Type</description>
        <formula>NOT($User.Bypass_Workflow__c) &amp;&amp; RecordType.DeveloperName = &apos;Renewal_Opportunity&apos; &amp;&amp;  ISCHANGED( TECH_NbOfVehiclesBasedOnContracts__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Clear %27Need review%27 field on Opportunity</fullName>
        <actions>
            <name>UncheckNeedReviewbyUseronOpp</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>CRM V2 - Clears the field &apos;Need Review&apos; when a user edits an opportunity</description>
        <formula>AND( Need_Review_By_User__c ,  CreatedDate &lt;&gt;  LastModifiedDate )</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
