    <rules>
        <fullName>FRA - Update Contact creation flag</fullName>
        <actions>
            <name>Updatedataflowcreationflag</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND(NOT($User.Bypass_Workflow__c), RecordTypeId = &quot;01220000000Cm8X&quot;, OR( ISPICKVAL(Role__c,&quot;1 - Contractuel, offres commerciales&quot;), ISPICKVAL(Role__c,&quot;2 - Logistique, editique&quot;) ), trim(Local_Broker_Id__c)=&apos;&apos;, text(Data_Flow_Creation_Flag__c)=&apos;&apos;, OR( Account.RecordTypeId = &apos;01220000000Cm83&apos;, Account.RecordTypeId = &apos;012200000008pQB&apos;, Account.RecordTypeId = &apos;01220000000E0nr&apos;, Account.RecordTypeId = &apos;01220000000E0nw&apos;,Account.RecordType.DeveloperName=&apos;Account_France_Prospect_Parcours&apos;,Account.RecordType.DeveloperName=&apos;Account_France_Customer_Parcours&apos;),IF(Account.Local_CALDER_ID__c&lt;&gt;&apos;&apos;,OR(BEGINS(Account.Local_CALDER_ID__c , &apos;T&apos;),BEGINS(Account.Local_CALDER_ID__c , &apos;B&apos;)), TRUE) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Update Contact modification flag</fullName>
        <actions>
            <name>Empty_Rejection_Cause_Contact</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Updatedataflowmodificationflag</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>JFF 28/10/2011 Test on local_customer_id at toplevel
CRM V2 - used by data flows to detect contact modification</description>
        <formula>AND(NOT($User.Bypass_Workflow__c), $User.Id &lt;&gt; &apos;00520000002jAYc&apos;, $User.Id &lt;&gt; &apos;00520000000pJKv&apos;,  	AND(  		RecordTypeId  = &quot;01220000000Cm8X&quot;, 		Account.Local_CALDER_ID__c&lt;&gt;&apos;&apos;, 		Local_Broker_Id__c&lt;&gt;&apos;&apos;, 		OR( 			ISPICKVAL(Role__c,&quot;1 - Contractuel, offres commerciales&quot;), 			ISPICKVAL(Role__c,&quot;2 - Logistique, editique&quot;) 		), 		OR( 			ISCHANGED(LastName),   			ISCHANGED(FirstName),  			ISCHANGED(Salutation),  			ISCHANGED(Phone),   			ISCHANGED(Role__c ),  			ISCHANGED(Function_List__c ), 			ISCHANGED(AccountId ), 			ISCHANGED( Email ), 			ISCHANGED( Language__c ), 			ISCHANGED( MailingCity ), 			ISCHANGED( MailingCountry ), 			ISCHANGED( MailingPostalCode ), 			ISCHANGED( MailingState ), 			ISCHANGED( MailingStreet ), 			ISCHANGED( Type__c ) 		), 		OR( Account.RecordTypeId = &apos;01220000000Cm83&apos;, Account.RecordTypeId = &apos;012200000008pQB&apos;, Account.RecordTypeId = &apos;01220000000E0nr&apos;,Account.RecordTypeId = &apos;01220000000E0nw&apos;,Account.RecordType.DeveloperName=&apos;Account_France_Prospect_Parcours&apos;,Account.RecordType.DeveloperName=&apos;Account_France_Customer_Parcours&apos;), 			OR(BEGINS(Account.Local_CALDER_ID__c , &apos;T&apos;),BEGINS(Account.Local_CALDER_ID__c , &apos;B&apos;)) 	) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
