    <rules>
        <fullName>Contract Extended</fullName>
        <actions>
            <name>checkextended</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>jff 2012/11/07 --&gt; adding (PriorValue)&amp;remove temporaly (waiting update from broker)
 AND(ISCHANGED( Contract_Term_Extension__c),</description>
        <formula>AND(NOT($User.Bypass_Workflow__c), OR(PRIORVALUE( Contract_End_Date_Calculated__c ) &lt; Contract_End_Date_Calculated__c,PRIORVALUE( ContractTerm) &lt; ContractTerm,  PRIORVALUE( Contract_Term_Extension__c)&lt;Contract_Term_Extension__c),  PRIORVALUE( Status2__c)=&apos;Live&apos;,  Status2__c=&apos;Live&apos;)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
