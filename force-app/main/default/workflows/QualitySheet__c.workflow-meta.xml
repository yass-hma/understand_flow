    <rules>
        <fullName>FRA - Quality Sheets - Notify Owner Transfer</fullName>
        <actions>
            <name>FRA_FQ_Notify_Sender_Owner_Changed</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>Send an email alert when the Owner is changed from a User to another User</description>
        <formula>AND(NOT($User.Bypass_Workflow__c), LEFT(OwnerId, 3) == &apos;005&apos;, ISCHANGED(OwnerId))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets - OwnerUpdateByDQ</fullName>
        <actions>
            <name>FRA_FQ_DTOwnerUpdateByQS</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Update a field used for sending Timed Email alerts</description>
        <formula>NOT($User.Bypass_Workflow__c) &amp;&amp; ISChanged(OwnerId) &amp;&amp; PRIORVALUE(OwnerId) ==  $Label.QS_Direction_Qualit</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets OptionEditZone</fullName>
        <actions>
            <name>FRA_UpdateRecodType</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>Used to change RecordType</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets Update Assignement Date</fullName>
        <actions>
            <name>FRA_UpdateAssignementDate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.Status__c</field>
            <operation>equals</operation>
            <value>Opened</value>
        </criteriaItems>
        <description>This WR update the assignment date when the status is Open</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets Update Closed Date</fullName>
        <actions>
            <name>FRA_QualitySheetsUpdate_Closed_Date</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.Status__c</field>
            <operation>equals</operation>
            <value>Closed</value>
        </criteriaItems>
        <description>Update closedDate when status is Closed</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets Update Decision DQ Date</fullName>
        <actions>
            <name>FRA_QualitySheetsUpdateDecisionDQDate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.Status__c</field>
            <operation>equals</operation>
            <value>DQ decision</value>
        </criteriaItems>
        <description>Update Decision DQ date  when status is  DQ decision</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets Update Reopen Date</fullName>
        <actions>
            <name>FRA_QualitySheetsUpdateClosedDate</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>FRA_QualitySheetsUpdateReopenedDate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.Status__c</field>
            <operation>equals</operation>
            <value>Reopened</value>
        </criteriaItems>
        <description>Update Reopened Date when status is Reopened</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets-Initiation Sender</fullName>
        <actions>
            <name>FRA_InitationSender</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>FRA_UpdateOwner</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>QualitySheet__c.OwnerId</field>
            <operation>notEqual</operation>
            <value>1H1</value>
        </criteriaItems>
        <description>Initiate the Sender field with the Owner</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>FRA - Quality Sheets-Notify Owner</fullName>
        <actions>
            <name>FRA_NotifyOwner</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>Notify Owner when the FQ is Closed</description>
        <formula>AND(ISCHANGED( Status__c ),  ISPICKVAL( Status__c , &apos;Closed&apos;) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
